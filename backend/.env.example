# Football Predictor - Environment Variables
# Copiați în .env și completați cu cheile voastre

# API-Football (gratuit: 100 req/zi la api-sports.io)
# Înregistrare: https://dashboard.api-football.com/
API_FOOTBALL_KEY=your_api_football_key_here

# football-data.org (gratuit: 10 req/min)
# Înregistrare: https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=your_football_data_key_here

# Server config
HOST=0.0.0.0
PORT=8000
DEBUG=true
